# Copier en .env et remplir les valeurs
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLIC_KEY=
VITE_OPENAI_API_KEY=

# Vercel : clé serveur pour le proxy OpenAI (jamais exposée au client)
OPENAI_API_KEY=
VITE_CLARITY_ID=
VITE_GA_ID=
# Optionnel : monitoring erreurs en production
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# Push notifications PWA (générer avec: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=
# Vercel : VAPID_PUBLIC_KEY et VAPID_PRIVATE_KEY (même public que VITE_VAPID_PUBLIC_KEY)
